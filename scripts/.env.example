# ============================================================
# Credenciales de PostgreSQL para migraciones en producción
# ============================================================
# Copiá este archivo como scripts/.env y completá los valores.
# NUNCA commitees scripts/.env al repositorio.
#
# Uso: node scripts/migrate-prod.js
# ============================================================

PG_HOST=xxx.xxx.xxx.xxx
PG_PORT=5432
PG_DATABASE=consultorio_medico
PG_SUPERUSER=postgres
PG_SUPERUSER_PASSWORD=cambiar_esto
PG_APP_USER=dashboard_user
PG_APP_PASSWORD=cambiar_esto
