{
  "name": "03 - Recordatorios Automáticos",
  "nodes": [
    {
      "id": "cron-trigger",
      "name": "Cron - Cada Hora",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 2,
      "position": [0, 300],
      "parameters": {
        "triggerTimes": {
          "item": [
            { "mode": "everyHour", "hour": 0, "minute": 0 }
          ]
        }
      }
    },
    {
      "id": "query-24h",
      "name": "PG - Turnos Próximas 24hs",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [250, 150],
      "credentials": {
        "postgres": { "id": "fersBxOXicK7tW99", "name": "Consultorio - postgres" }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT t.id, t.fecha_hora, t.estado,\n  p.id as paciente_id, p.nombre, p.apellido, p.telefono,\n  m.nombre as medico_nombre\nFROM turnos t\nJOIN pacientes p ON p.id = t.paciente_id\nJOIN medicos m ON m.id = t.medico_id\nWHERE t.estado IN ('pendiente', 'confirmada')\n  AND t.recordatorio_24h_enviado = FALSE\n  AND t.fecha_hora BETWEEN NOW() AND NOW() + INTERVAL '24 hours'\n  AND t.fecha_hora > NOW() + INTERVAL '1 hour' -- no overlap with 1h reminders\n  AND p.consentimiento_whatsapp = TRUE\n  AND EXTRACT(HOUR FROM NOW()) BETWEEN 8 AND 20 -- solo horario diurno\nORDER BY t.fecha_hora;"
      }
    },
    {
      "id": "query-1h",
      "name": "PG - Turnos Próxima 1h",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [250, 450],
      "credentials": {
        "postgres": { "id": "fersBxOXicK7tW99", "name": "Consultorio - postgres" }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT t.id, t.fecha_hora, t.estado,\n  p.id as paciente_id, p.nombre, p.apellido, p.telefono,\n  m.nombre as medico_nombre\nFROM turnos t\nJOIN pacientes p ON p.id = t.paciente_id\nJOIN medicos m ON m.id = t.medico_id\nWHERE t.estado IN ('pendiente', 'confirmada')\n  AND t.recordatorio_1h_enviado = FALSE\n  AND t.fecha_hora BETWEEN NOW() AND NOW() + INTERVAL '1 hour'\n  AND p.consentimiento_whatsapp = TRUE\n  AND EXTRACT(HOUR FROM NOW()) BETWEEN 8 AND 20 -- solo horario diurno\nORDER BY t.fecha_hora;"
      }
    },
    {
      "id": "if-24h",
      "name": "¿Hay turnos 24h?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [500, 150],
      "parameters": {
        "conditions": {
          "number": [
            { "value1": "={{ $items().length }}", "operation": "larger", "value2": 0 }
          ]
        }
      }
    },
    {
      "id": "if-1h",
      "name": "¿Hay turnos 1h?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [500, 450],
      "parameters": {
        "conditions": {
          "number": [
            { "value1": "={{ $items().length }}", "operation": "larger", "value2": 0 }
          ]
        }
      }
    },
    {
      "id": "template-24h",
      "name": "Plantilla 24h: Armar Mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [750, 100],
      "parameters": {
        "language": "javaScript",
        "code": "// Template: Recordatorio 24h\n// Editá este contenido desde el Dashboard en Configuración → Plantillas WhatsApp\nconst TEMPLATE = `👋 Hola {{nombre}}! Te recordamos que tenés un turno mañana {{fecha_hora}} con {{medico_nombre}}. Respondé CONFIRMAR para confirmar tu asistencia. ¡Gracias! 😊`;\n\nreturn items.map(item => {\n  let body = TEMPLATE;\n  const vars = item.json;\n  // Reemplazar {{variables}} con los valores del turno\n  body = body.replace(/\\{\\{\\s*(\\w+)\\s*\\}\\}/g, (match, key) => {\n    return vars[key] !== undefined ? String(vars[key]) : match;\n  });\n  return { json: { ...vars, body } };\n});"
      }
    },
    {
      "id": "template-1h",
      "name": "Plantilla 1h: Armar Mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [750, 400],
      "parameters": {
        "language": "javaScript",
        "code": "// Template: Recordatorio 1h\n// Editá este contenido desde el Dashboard en Configuración → Plantillas WhatsApp\nconst TEMPLATE = `⏰ Recordatorio: en 1 hora tenés turno con {{medico_nombre}}. Te esperamos! 🏥`;\n\nreturn items.map(item => {\n  let body = TEMPLATE;\n  const vars = item.json;\n  body = body.replace(/\\{\\{\\s*(\\w+)\\s*\\}\\}/g, (match, key) => {\n    return vars[key] !== undefined ? String(vars[key]) : match;\n  });\n  return { json: { ...vars, body } };\n});"
      }
    },
    {
      "id": "twilio-24h",
      "name": "Twilio - Recordatorio 24h",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 2,
      "position": [1000, 100],
      "credentials": {
        "twilioApi": { "id": "aE31QgQsM9spWb5a", "name": "Consultorio - Twilio API" }
      },
      "parameters": {
        "resource": "message",
        "operation": "create",
        "to": "={{ 'whatsapp:+549' + $json.telefono }}",
        "from": "={{ $env.TWILIO_WHATSAPP_NUMBER }}",
        "body": "={{ $json.body }}"
      }
    },
    {
      "id": "twilio-1h",
      "name": "Twilio - Recordatorio 1h",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 2,
      "position": [1000, 400],
      "credentials": {
        "twilioApi": { "id": "aE31QgQsM9spWb5a", "name": "Consultorio - Twilio API" }
      },
      "parameters": {
        "resource": "message",
        "operation": "create",
        "to": "={{ 'whatsapp:+549' + $json.telefono }}",
        "from": "={{ $env.TWILIO_WHATSAPP_NUMBER }}",
        "body": "={{ $json.body }}"
      }
    },
    {
      "id": "mark-24h",
      "name": "PG - Marcar Recordatorio 24h",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [1250, 100],
      "credentials": {
        "postgres": { "id": "fersBxOXicK7tW99", "name": "Consultorio - postgres" }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE turnos SET recordatorio_24h_enviado = TRUE, updated_at = NOW() WHERE id = $1;",
        "additionalFields": {
          "queryParams": "={{ [$json.id] }}"
        }
      }
    },
    {
      "id": "mark-1h",
