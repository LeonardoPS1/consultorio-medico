    {
      "id": "log",
      "name": "PG - Log de Envío",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [1500, 250],
      "credentials": {
        "postgres": { "id": "fersBxOXicK7tW99", "name": "Consultorio - postgres" }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO workflow_logs (workflow_id, execution_id, nivel, mensaje, metadata)\nVALUES ('workflow-03', $1, 'info', $2, $3);",
        "additionalFields": {
          "queryParams": "={{ [$json.executionId, 'Recordatorio enviado - turno: ' + $json.id, JSON.stringify({turno_id: $json.id, paciente: $json.nombre + ' ' + $json.apellido})] }}"
        }
      }
    }
  ],
