      "parameters": {
        "method": "POST",
        "url": "https://med.aicorebots.com/api/internal/scores/actualizar",
        "authentication": "none",
        "options": {
          "timeout": 30000
        },
        "headers": {
          "Content-Type": "application/json",
          "x-internal-key": "={{ $env.INTERNAL_API_KEY }}"
        },
        "jsonParameters": true,
        "parameters": {
          "diasAntelacion": 30
        }
      }
    },
    {
      "id": "if-success",
      "name": "¿Éxito?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [750, 300],
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.mensaje }}",
              "operation": "contains",
              "value2": "actualizados"
            }
          ]
        }
      }
    },
    {
      "id": "log-success",
      "name": "PG - Log Éxito",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [1000, 200],
      "credentials": {
        "postgres": {
          "id": "fersBxOXicK7tW99",
          "name": "Consultorio - postgres"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO workflow_logs (workflow_id, execution_id, nivel, mensaje, metadata) VALUES ('workflow-12', $1, 'info', $2, $3);",
        "additionalFields": {
          "queryParams": "={{ [$json.executionId, $json.mensaje, JSON.stringify($json) ] }}"
        }
      }
    },
    {
      "id": "log-error",
      "name": "PG - Log Error",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [1000, 400],
      "credentials": {
        "postgres": {
          "id": "fersBxOXicK7tW99",
          "name": "Consultorio - postgres"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO workflow_logs (workflow_id, execution_id, nivel, mensaje, metadata) VALUES ('workflow-12', $1, 'error', $2, $3);",
        "additionalFields": {
          "queryParams": "={{ [$json.executionId, 'Error actualizando scores: ' + $json.error?.message || 'Error desconocido', JSON.stringify($json) ] }}"
        }
      }
    }
