{
  "name": "12 - Actualizar Scores No-Show",
  "nodes": [
    {
      "id": "cron-trigger",
      "name": "Cron - Diario 03:30",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 2,
      "position": [250, 300],
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyDay",
