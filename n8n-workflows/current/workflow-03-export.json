      "typeVersion": 3.4,
      "position": [
        1250,
        150
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "recordatorioMensaje",
              "value": "=Hola {{ $json.nombre }}! Te recordamos que tenes un turno manana {{ $json.fecha_hora }} con {{ $json.medico_nombre }}. Responde CONFIRMAR para confirmar tu asistencia. Gracias!",
              "type": "string"
