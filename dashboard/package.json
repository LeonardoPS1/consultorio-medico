{
  "name": "consultorio-medico-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "build:standalone": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "node .next/standalone/server.js",
    "start:dev": "next start --port 3000",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/core": "^0.34.0",
    "@auth/drizzle-adapter": "^1.0.0",
    "@fullcalendar/core": "^6.1.0",
    "@fullcalendar/daygrid": "^6.1.0",
    "@fullcalendar/interaction": "^6.1.0",
    "@fullcalendar/react": "^6.1.0",
    "@fullcalendar/timegrid": "^6.1.0",
    "@hookform/resolvers": "^3.3.0",
    "@radix-ui/react-avatar": "^1.0.0",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-label": "^2.0.0",
    "@radix-ui/react-scroll-area": "^1.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.0",
    "@radix-ui/react-switch": "^1.0.0",
    "@radix-ui/react-tabs": "^1.0.0",
    "@radix-ui/react-toast": "^1.1.0",
    "@t3-oss/env-nextjs": "^0.10.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-table": "^8.17.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.0",
    "drizzle-orm": "^0.31.0",
    "lucide-react": "^0.378.0",
    "mercadopago": "^2.12.1",
    "next": "^14.2.0",
    "next-auth": "^5.0.0-beta.19",
    "next-themes": "^0.4.6",
    "pdfkit": "^0.18.0",
    "postgres": "^3.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-day-picker": "^8.10.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.0",
    "recharts": "^2.12.0",
    "speakeasy": "^2.0.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.0",
    "twilio": "^5.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.35",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/speakeasy": "^2.0.10",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.22.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "vitest run --related --reporter=verbose"
    ]
  }
}
