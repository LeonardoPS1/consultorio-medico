# =============================================================================
# Variables de Entorno — AicoreMed · Consultorio Médico (Chile)
#
# Copia este archivo como .env.local y completa los valores reales.
# ⚠️  NUNCA commitees .env.local al repositorio.
# ⚠️  En producción, usar las variables de entorno de Dokploy.
# =============================================================================

# ─── Base de Datos ───────────────────────────────────────────────────────────
# La app se conecta a PgBouncer (:6432) o directamente a PG (:5432).
#
# ✅ Producción (con PgBouncer en Docker):
#   DATABASE_URL="postgresql://dashboard_user:pass@pgbouncer:6432/consultorio_medico"
#   DATABASE_URL_DIRECT="postgresql://dashboard_user:pass@postgres:5432/consultorio_medico"
#
# 🖥️ Desarrollo local directo (sin PgBouncer):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/consultorio_medico"
#   # DATABASE_URL_DIRECT no es necesario si usás conexión directa
#
DATABASE_URL="postgresql://postgres:postgres@pgbouncer:6432/consultorio_medico"
DATABASE_URL_DIRECT="postgresql://postgres:postgres@postgres:5432/consultorio_medico"

# ─── Autenticación ───────────────────────────────────────────────────────────
# 🔴 OBLIGATORIO en producción: generar con:
#    openssl rand -base64 32
AUTH_SECRET="run-openssl-rand-base64-32-to-generate"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Twilio (WhatsApp) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="your_account_sid"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
TWILIO_DOCTOR_NUMBER="whatsapp:+569XXXXXXXX"

# ─── Ollama (IA Local) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"
# ⚠️ Modelos disponibles actualmente: gemma3, llama3.2
OLLAMA_MODEL="gemma3"

# ─── MercadoPago ───────────────────────────────────────────────────────────
# Obtén credenciales TEST desde https://www.mercadopago.cl/developers
MERCADOPAGO_ACCESS_TOKEN="your_mercadopago_access_token"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="your_mercadopago_public_key"
MERCADOPAGO_WEBHOOK_SECRET="your_webhook_secret"
MERCADOPAGO_CURRENCY="CLP"
MERCADOPAGO_SUCCESS_URL="http://localhost:3000/dashboard/configuracion?tab=suscripcion&success=1"
MERCADOPAGO_FAILURE_URL="http://localhost:3000/dashboard/configuracion?tab=suscripcion&failure=1"
MERCADOPAGO_PENDING_URL="http://localhost:3000/dashboard/configuracion?tab=suscripcion&pending=1"

# ─── White-Label (AicoreMed Chile) ─────────────────────────────────────────
# Personalización por tenant (se leen en build-time por ahora)
NEXT_PUBLIC_TENANT_NAME="Consultorio Médico - Chile"
NEXT_PUBLIC_TENANT_PRIMARY="#2563eb"

# ─── Certificados Médicos ────────────────────────────────────────────────────
# 🔴 OBLIGATORIO en producción: generar con:
#    openssl rand -hex 32
CERTIFICADO_HASH_SECRET="run-openssl-rand-hex-32-to-generate"

# ─── Novedades (WF-11) ────────────────────────────────────────
# 🔴 Compartido entre dashboard y n8n para auto-generación de novedades desde commits
#    Generar con: openssl rand -hex 32
NOVEDADES_INTERNAL_KEY="run-openssl-rand-hex-32-to-generate"

# ─── n8n (opcional) ─────────────────────────────────────────────────────────
N8N_BASE_URL="http://localhost:5678"
N8N_API_KEY="your_n8n_api_key"
N8N_WEBHOOK_INBOUND_URL="http://localhost:5678/webhook/consultorio-inbound"
N8N_WEBHOOK_SECRET="aicoremed-secret-key-2026"

# ─── Web Push / Notificaciones Push (opcional) ───────────────────────────────
# Generar con: node -e "const wp=require('web-push');console.log(JSON.stringify(wp.generateVAPIDKeys()))"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your_vapid_public_key"
VAPID_PRIVATE_KEY="your_vapid_private_key"
VAPID_CONTACT_EMAIL="mailto:notificaciones@aicoremed.com"

# ─── Google Calendar (opcional) ─────────────────────────────────────────────
GOOGLE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----"
GOOGLE_CALENDAR_ID="primary"

# ─── LiveKit (Videoconsultas, opcional) ──────────────────────────────────────
# Generar API Key/Secret con:
#   docker run livekit/livekit-server -- generate-keys
# O usar valores generados al deployar LiveKit server.
LIVEKIT_URL="wss://livekit.aicorebots.com"
LIVEKIT_API_KEY="your_livekit_api_key"
LIVEKIT_API_SECRET="your_livekit_api_secret"

# ─── Email (IMAP/SMTP, opcional) ────────────────────────────────────────────
IMAP_HOST="imap.gmail.com"
IMAP_PORT=993
IMAP_USER="your@email.com"
IMAP_PASSWORD="your-app-password"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASSWORD="your-app-password"
